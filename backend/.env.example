# ======================================
# SERVER CONFIGURATION
# ======================================
NODE_ENV=development
PORT=5000

# ======================================
# DATABASE CONFIGURATION
# ======================================
# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/hotel_app?retryWrites=true&w=majority

# ======================================
# CLIENT CONFIGURATION
# ======================================
# Frontend URL for CORS (use * for development, specific URL for production)
CLIENT_URL=http://localhost:5173

# ======================================
# JWT AUTHENTICATION
# ======================================
# Secret key for JWT token generation (MUST be at least 32 characters)
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-long-super-secret-jwt-key-change-this-in-production-minimum-32-characters

# JWT Token Expiration (e.g., 7d, 30d, 1h)
JWT_EXPIRE=7d

# ======================================
# EMAIL CONFIGURATION (SMTP)
# ======================================
# Gmail Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Your Gmail address
SMTP_EMAIL=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# How to get: https://support.google.com/accounts/answer/185833
SMTP_PASSWORD=your-gmail-app-specific-password

# Email sender information
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Your Hotel Name

# ======================================
# RATE LIMITING (Optional - defaults in code)
# ======================================
# API_RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
# API_RATE_LIMIT_MAX=100         # Max requests per window
# AUTH_RATE_LIMIT_WINDOW=900000  # 15 minutes
# AUTH_RATE_LIMIT_MAX=5          # Max login attempts
# SUBMISSION_RATE_LIMIT_WINDOW=3600000  # 1 hour in milliseconds
# SUBMISSION_RATE_LIMIT_MAX=10           # Max public form submissions per window

# ======================================
# API REQUEST LOGGER (Optional - defaults in code)
# ======================================
# Set to false to disable request logging entirely
# API_LOGGER_ENABLED=true

# Logger level: error, warn, info, http, verbose, debug, silly
# API_LOGGER_LEVEL=info

# Pretty-print logs (recommended in development)
# API_LOGGER_PRETTY=true

# Log request body (defaults to true outside production)
# API_LOGGER_BODY=true

# Log response body (defaults to false)
# API_LOGGER_RESPONSE_BODY=false

# Max characters logged for body preview
# API_LOGGER_MAX_LENGTH=1000

# ======================================
# SECURITY NOTES
# ======================================
# 1. NEVER commit this file with real values to version control
# 2. Change JWT_SECRET to a strong random string in production
# 3. Use Gmail App Passwords, not your Google account password
# 4. Restrict CLIENT_URL to your actual frontend domain in production
# 5. Keep MongoDB credentials secure
# 6. Rotate secrets regularly
